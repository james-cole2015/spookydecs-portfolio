.DS_Store
.py
.json
merge.py
# Vite/Node
node_modules/
dist/
*.local

# Lock files (choose one based on your package manager)
package-lock.json
# or
yarn.lock
# or
pnpm-lock.yaml

# Optional: if you want to keep dev config out of repo
/public
package.json 
vite.config.js
app_docs/


# React subs: build manifests MUST be committed so CI `npm ci && npm run build`
# can run. These wildcards negate the global package.json / package-lock.json
# ignores above for every sub at once (storage #267 + the #330-#341 migration fleet),
# so a new React sub needs no .gitignore edit. (dist/ and node_modules/ stay ignored.)
!subs/*/package.json
!subs/*/package-lock.json

# Workspace root + ui package manifests must be committed for CI to work.
!package.json
!package-lock.json
!packages/*/package.json
!packages/*/package-lock.json

CLAUDE.md
.env.example
scripts/backfill_tasks.py
scripts/seed_epics.py
scripts/*
# Design-conformance checker + its shared scaffolding and manifest are the one
# exception to the local-only scripts/ convention: the design-conformance.yml
# GHA workflow (#504) runs them on every PR, so they must be tracked.
!scripts/scan_common.py
!scripts/check_design_conformance.py
!scripts/design-conformance.yaml
lambda_creation_log.txt
fail-log.txt

# Local-only infra verifier (AWS-credentialed; not committed)
scripts/verify_sub_infra.py
