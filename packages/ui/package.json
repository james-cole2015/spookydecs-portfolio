{
  "name": "@spookydecs/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared React component library for SpookyDecs subs.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js",
      "default": "./dist/theme.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --declarationDir dist"
  },
  "peerDependencies": {
    "@heroui/react": ">=2",
    "framer-motion": ">=11",
    "lucide-react": ">=0.4",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@heroui/react": "^2.6.14",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.5.4"
  }
}
