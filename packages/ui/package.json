{
  "name": "@spookydecs/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared React component library for SpookyDecs subs.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js",
      "default": "./dist/theme.js"
    },
    "./tailwind-preset": {
      "import": "./tailwind-preset.js",
      "default": "./tailwind-preset.js"
    },
    "./vite-cdn-dev": {
      "types": "./vite-cdn-dev.d.ts",
      "import": "./vite-cdn-dev.js",
      "default": "./vite-cdn-dev.js"
    }
  },
  "files": ["dist", "tailwind-preset.js", "vite-cdn-dev.js", "vite-cdn-dev.d.ts"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --declarationDir dist"
  },
  "dependencies": {
    "photoswipe": "^5.4.4",
    "react-photoswipe-gallery": "^4.1.2"
  },
  "peerDependencies": {
    "@heroui/react": ">=2",
    "framer-motion": ">=11",
    "lucide-react": ">=0.4",
    "react": ">=18",
    "react-dom": ">=18",
    "react-router-dom": ">=6"
  },
  "devDependencies": {
    "@heroui/react": "^2.6.14",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.5.4"
  }
}
